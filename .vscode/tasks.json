{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install",
      "type": "shell",
      "command": "npm install",
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "tauri: dev",
      "type": "shell",
      "command": "npm run tauri:dev",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "tauri: build",
      "type": "shell",
      "command": "npm run tauri:build",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "frontend: build",
      "type": "shell",
      "command": "npm run build",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "rust: check",
      "type": "shell",
      "command": "cargo check",
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "group": "test",
      "problemMatcher": "$rustc"
    },
    {
      "label": "rust: build",
      "type": "shell",
      "command": "cargo build",
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "app: prepare debug",
      "dependsOrder": "sequence",
      "dependsOn": [
        "frontend: build",
        "rust: build"
      ],
      "group": "build",
      "problemMatcher": []
    }
  ]
}
